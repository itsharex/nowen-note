+/* 无序列表符号显式覆盖 1～9 层；更深层级沿用第 9 层样式。 */
+.ProseMirror ul ul { --nowen-ul-marker: "◦"; --nowen-ul-marker-size: 1.1em; --nowen-ul-marker-top: 0; }
